{
  "name": "@fullstack-dev/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start nestjs api": "nx serve backebd --watch",
    "prisma:generate": "npx prisma generate --schema libs/prisma-schema-one/prisma && npx prisma generate --schema libs/prisma-schema-two/prisma",
    "prisma-migrate": "dotenv -e ../.env -- npx prisma migrate dev --schema libs/prisma-schema-one/prisma && npx prisma migrate dev --schema libs/prisma-schema-two/prisma",
    "pnpm-instal": "pnpm install --no-frozen-lockfile",
    "pnpm-auto-update": "pnpm update",
    "nxupdate": "nx migrate latest",
    "nxmigrate": "nx migrate --run-migrations"
  },
  "private": true,
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "axios": "^1.6.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint": "21.3.11",
    "@nx/eslint-plugin": "21.3.11",
    "@nx/js": "21.3.11",
    "@nx/nest": "21.3.11",
    "@nx/node": "21.3.11",
    "@nx/web": "21.3.11",
    "@nx/webpack": "21.3.11",
    "@nx/workspace": "21.3.11",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/node": "~18.16.9",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "nx": "21.3.11",
    "prettier": "^2.6.2",
    "tslib": "^2.3.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.29.0",
    "webpack-cli": "^5.1.4"
  },
  "workspaces": [
    "apps/*"
  ]
}
